{
  "openapi": "3.0.3",
  "info": {
    "title": "社員情報 CRUD API",
    "description": "HR部門向け社員情報管理 REST API。新規登録、取得、更新、削除機能を提供。",
    "version": "1.0.0",
    "contact": {
      "name": "開発チーム",
      "email": "hr-api@example.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "ローカル開発環境"
    },
    {
      "url": "http://api.example.com",
      "description": "本番環境"
    }
  ],
  "paths": {
    "/employees": {
      "get": {
        "summary": "社員一覧取得",
        "description": "登録されている全社員情報を取得（削除済みを除く）",
        "operationId": "list_employees",
        "tags": ["Employees"],
        "responses": {
          "200": {
            "description": "取得成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeListResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "社員情報新規登録",
        "description": "新しい社員情報を登録する。name, email, department は必須。",
        "operationId": "create_employee",
        "tags": ["Employees"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "登録成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストの検証エラー（必須項目不足、形式不正など）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "重複エラー（メールアドレスが既に登録されおります）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/employees/{id}": {
      "get": {
        "summary": "社員情報取得（単体）",
        "description": "指定した ID の社員情報を取得。削除済みの場合は 404 を返す。",
        "operationId": "get_employee",
        "tags": ["Employees"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "社員ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "取得成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeResponse"
                }
              }
            }
          },
          "404": {
            "description": "社員が見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "社員情報更新（全項目）",
        "description": "指定した ID の社員情報をすべて置き換える。name, email, department はすべて必須。",
        "operationId": "update_employee",
        "tags": ["Employees"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "社員ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストの検証エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "社員が見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "重複エラー（メールアドレスが既に他の社員に使用されています）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "社員情報更新（部分）",
        "description": "指定した ID の社員情報の一部を更新。変更したいフィールドのみ指定可能。",
        "operationId": "patch_employee",
        "tags": ["Employees"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "社員ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeePatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストの検証エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "社員が見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "重複エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConflictErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "社員情報削除（論理削除）",
        "description": "指定した ID の社員情報を削除する。DB からは削除せず、is_deleted フラグを true に設定。",
        "operationId": "delete_employee",
        "tags": ["Employees"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "社員ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "204": {
            "description": "削除成功（本文なし）"
          },
          "404": {
            "description": "社員が見つかりません",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "サーバーエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EmployeeCreateRequest": {
        "type": "object",
        "required": ["name", "email", "department"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "田中太郎"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "taro@example.com"
          },
          "department": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "営業部"
          }
        }
      },
      "EmployeeUpdateRequest": {
        "type": "object",
        "required": ["name", "email", "department"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "田中太郎"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "taro@example.com"
          },
          "department": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "営業部"
          }
        }
      },
      "EmployeePatchRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "example": "田中太郎"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "taro@example.com"
          },
          "department": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "example": "営業部"
          }
        }
      },
      "EmployeeResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "田中太郎"
          },
          "email": {
            "type": "string",
            "example": "taro@example.com"
          },
          "department": {
            "type": "string",
            "example": "営業部"
          },
          "is_deleted": {
            "type": "boolean",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-02T10:30:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-02T10:30:00Z"
          }
        }
      },
      "EmployeeListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmployeeResponse"
            }
          },
          "total": {
            "type": "integer",
            "example": 10
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "example": "データベース接続エラー"
          },
          "status_code": {
            "type": "integer",
            "example": 500
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "example": "email"
                },
                "message": {
                  "type": "string",
                  "example": "invalid email format"
                }
              }
            }
          },
          "status_code": {
            "type": "integer",
            "example": 400
          }
        }
      },
      "ConflictErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "example": "このメールアドレスは既に登録されています"
          },
          "status_code": {
            "type": "integer",
            "example": 409
          }
        }
      },
      "NotFoundErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "example": "社員が見つかりません"
          },
          "status_code": {
            "type": "integer",
            "example": 404
          }
        }
      }
    }
  }
}
